# Copy this file to .env and fill in your values.
# Never commit .env — it is in .gitignore.

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=carflip
POSTGRES_USER=carflip
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql://carflip:changeme@database:5432/carflip

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Google AI Studio (Gemini) ─────────────────────────────────────────────────
# Get a free API key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash-lite

# ── DVSA MOT API ──────────────────────────────────────────────────────────────
# Register at https://developer-portal.driver-vehicle-licensing.api.gov.uk/
DVSA_CLIENT_ID=your_dvsa_client_id
DVSA_CLIENT_SECRET=your_dvsa_client_secret
DVSA_API_URL=https://history.mot.api.gov.uk

# ── DVLA Vehicle Enquiry (optional) ──────────────────────────────────────────
DVLA_API_KEY=

# ── Web UI — HTTP Basic admin access ─────────────────────────────────────────
AUTH_USER=admin
AUTH_PASS=changeme

# ── JWT (user-facing auth) ────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=changeme-please-set-a-strong-random-secret

# ── Stripe billing (optional) ────────────────────────────────────────────────
# Get keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_BASIC_MONTHLY=
STRIPE_PRICE_BASIC_ANNUAL=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_ANNUAL=

# ── Proxy (optional) ──────────────────────────────────────────────────────────
PROXY_URL=

# ── Scraper — AutoTrader ──────────────────────────────────────────────────────
AUTOTRADER_RATE_LIMIT=30
AUTOTRADER_SEARCH_RADIUS=50
AUTOTRADER_SEARCH_POSTCODE=SW1A1AA

# ── Scraper — Gumtree ────────────────────────────────────────────────────────
GUMTREE_SEARCH_LOCATION=uk
GUMTREE_MAX_PRICE=0

# ── Scraper — Facebook Marketplace ───────────────────────────────────────────
# Export cookies after logging in to facebook.com using "Cookie-Editor" extension
# → Export as JSON → save to this path on the server
FB_COOKIES_PATH=/data/facebook_cookies.json
FB_LATITUDE=51.5074
FB_LONGITUDE=-0.1278
FB_RADIUS_KM=80
FB_MAX_PRICE=15000
FB_MIN_PRICE=500
