# Copy this file to .env and fill in your values.
# Never commit .env — it is in .gitignore.

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=autoflipr
POSTGRES_USER=autoflipr
POSTGRES_PASSWORD=changeme                    # CHANGE THIS
DATABASE_URL=postgresql://autoflipr:changeme@database:5432/autoflipr

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Google AI Studio (Gemini) ─────────────────────────────────────────────────
# Get free API keys at https://aistudio.google.com/app/apikey
# Comma-separated list — multiple keys enable round-robin to avoid rate limits
GEMINI_API_KEYS=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# ── DVSA MOT API ──────────────────────────────────────────────────────────────
# Register at https://developer-portal.driver-vehicle-licensing.api.gov.uk/
DVSA_CLIENT_ID=your_dvsa_client_id
DVSA_CLIENT_SECRET=your_dvsa_client_secret
DVSA_API_URL=https://history.mot.api.gov.uk

# ── DVLA Vehicle Enquiry (optional) ──────────────────────────────────────────
DVLA_API_KEY=

# ── JWT (user-facing auth) ────────────────────────────────────────────────────
# REQUIRED — generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=changeme-please-set-a-strong-random-secret

# ── Web UI — admin panel password ─────────────────────────────────────────────
AUTH_USER=admin
AUTH_PASS=changeme                            # CHANGE THIS

# ── CORS ──────────────────────────────────────────────────────────────────────
# Space-separated list of allowed frontend origins.
# In production include both apex and www; keep localhost for dev.
CORS_ORIGINS=https://autoflipr.com https://www.autoflipr.com http://localhost:5173

# ── Stripe billing ────────────────────────────────────────────────────────────
# Live keys from https://dashboard.stripe.com/apikeys  (use test keys for dev)
STRIPE_SECRET_KEY=sk_live_...
# Webhook secret — from Stripe Dashboard > Developers > Webhooks
# For local dev use the Stripe CLI: stripe listen --forward-to localhost:8000/api/billing/webhook
STRIPE_WEBHOOK_SECRET=whsec_...
# Price IDs from Stripe Dashboard > Product catalog
STRIPE_PRICE_BASIC_MONTHLY=price_...
STRIPE_PRICE_BASIC_ANNUAL=price_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_ANNUAL=price_...

# ── Proxy (optional) ──────────────────────────────────────────────────────────
# Rotating proxy URL for scraping at scale (e.g. Bright Data, Oxylabs)
PROXY_URL=

# ── Scraper — AutoTrader ──────────────────────────────────────────────────────
AUTOTRADER_RATE_LIMIT=30
AUTOTRADER_SEARCH_RADIUS=50
AUTOTRADER_SEARCH_POSTCODE=SW1A1AA

# ── Scraper — Gumtree ────────────────────────────────────────────────────────
GUMTREE_SEARCH_LOCATION=uk
GUMTREE_MAX_PRICE=0

# ── Scraper — Facebook Marketplace ───────────────────────────────────────────
# Export cookies after logging in to facebook.com using "Cookie-Editor" extension
# → Export as JSON → save to this path on the server (mounted at /data inside Docker)
FB_COOKIES_PATH=/data/facebook_cookies.json
FB_LATITUDE=51.5074
FB_LONGITUDE=-0.1278
FB_RADIUS_KM=80
FB_MAX_PRICE=15000
FB_MIN_PRICE=500
